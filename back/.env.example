PORT=3001
# Local development frontend URL.
FRONTEND_ORIGIN=http://localhost:5173
# In production, set FRONTEND_ORIGIN to your deployed frontend domain.
# Example: FRONTEND_ORIGIN=https://music-moods.vercel.app
JSON_BODY_LIMIT=10kb
MOOD_MAX_LENGTH=280
MOOD_RATE_LIMIT_WINDOW_MS=900000
MOOD_RATE_LIMIT_MAX=30
LOG_FORMAT=dev
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
